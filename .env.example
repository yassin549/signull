# Trading mode: "paper" (log only) or "live" (real orders)
TRADING_MODE=paper

# Asset series to trade: btc, eth, sol, xrp
ASSET=btc

# Order size in USDC per trade
ORDER_SIZE_USDC=5.0

# Max price willing to pay per share (0.01 - 0.99)
MAX_ENTRY_PRICE=0.55

# Bot trading loop interval (seconds) — market data is real-time via WebSocket
BOT_POLL_INTERVAL_SEC=2

# Dashboard push rate in milliseconds (lower = faster updates, 50 = 20/sec)
DASHBOARD_PUSH_MS=50

# Local dashboard server
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# --- Wallet / account (required for live trading) ---
# Your signing private key (never commit this)
PRIVATE_KEY=0x...

# Funder address = where your Polymarket funds live.
# Find it at https://polymarket.com/settings (copy "Profile Address")
FUNDER_ADDRESS=0x...

# Signature type — pick the one that matches how you use Polymarket:
#   0 = MetaMask / hardware wallet (EOA)
#   1 = Email or Google login (Magic/proxy wallet)
#   2 = Gnosis Safe
#   3 = New API deposit wallet (advanced — see docs)
SIGNATURE_TYPE=1