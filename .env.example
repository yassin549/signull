# Trading mode: "paper" (simulate fills on live markets) or "live" (real orders)
TRADING_MODE=paper

# Asset series to trade: btc, eth, sol, xrp
ASSET=btc

# Live strategy: signull_1_1 (calibrated Kelly) or signull_1_0 (legacy)
BOT_STRATEGY=signull_1_1

# --- Signull strategy ---
# Paper bankroll used for risk % sizing (also used as size base in live)
PAPER_INITIAL_CAPITAL=100
# Limit trigger + fill price (default 0.70 = 70¢ favorite)
SIGNULL_THRESHOLD=0.70
SIGNULL_MIN_RISK_PCT=0.05
SIGNULL_MAX_RISK_PCT=0.50
SIGNULL_TRUST_LOOKBACK=3
SIGNULL_BTC_ALIGN_MIN=0.55
SIGNULL_BIG_EQUITY_BUFFER=1.25

# Legacy flat size (unused by Signull 1.0 risk model; kept for reference)
ORDER_SIZE_USDC=5.0

# Max price willing to pay per share (legacy momentum strategy)
MAX_ENTRY_PRICE=0.55

# Bot trading loop interval (seconds) — market data is real-time via WebSocket
BOT_POLL_INTERVAL_SEC=2

# Dashboard push rate in milliseconds (lower = faster updates, 50 = 20/sec)
DASHBOARD_PUSH_MS=50

# Local dashboard server
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# --- Wallet / account (required for live trading) ---
# Your signing private key (never commit this)
PRIVATE_KEY=0x...

# Funder address = where your Polymarket funds live.
# Find it at https://polymarket.com/settings (copy "Profile Address")
FUNDER_ADDRESS=0x...

# Signature type — pick the one that matches how you use Polymarket:
#   0 = MetaMask / hardware wallet (EOA)
#   1 = Email or Google login (Magic/proxy wallet)
#   2 = Gnosis Safe
#   3 = New API deposit wallet (advanced — see docs)
SIGNATURE_TYPE=1
